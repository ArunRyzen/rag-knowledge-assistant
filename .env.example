# Copy to `.env`. All optional — the app runs offline with no keys.

# Embeddings (semantic). Without this, an offline hashing embedder is used.
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Answer generation. Without a key, a deterministic fake answerer is used.
GENERATION_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o
MAX_TOKENS=1024

# Vector store: memory (default) or pgvector
VECTOR_STORE=memory
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

# Retrieval tuning
TOP_K=5
CANDIDATE_K=20
USE_RERANKER=false
RRF_K=60

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120
