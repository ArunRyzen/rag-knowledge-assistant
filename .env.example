# Copy to `.env`. All optional — the app runs offline with no keys.

# ── Gemini (recommended: one free key covers embeddings AND answers) ──
# Get a key at https://aistudio.google.com/apikey and paste it here. When set, the pipeline
# uses Gemini for semantic embeddings and real answer synthesis.
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768
GEMINI_MODEL=gemini-2.5-flash

# ── Alternative providers (only if you have these keys) ──
# Embeddings via OpenAI. Without any key, an offline hashing embedder is used.
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Answer generation: gemini (default) | anthropic | openai.
# Without a key for the chosen provider, a deterministic fake answerer is used.
GENERATION_PROVIDER=gemini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o
MAX_TOKENS=1024

# Vector store: memory (default) or pgvector
VECTOR_STORE=memory
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

# Retrieval tuning
TOP_K=5
CANDIDATE_K=20
USE_RERANKER=false
RRF_K=60

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120
